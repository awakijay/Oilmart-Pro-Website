# Oilmart Pro production environment template.
# Copy this to .env for local runs, or to /etc/oilmart-pro/oilmart-pro.env
# when using the systemd unit in deploy/systemd/oilmart-pro.service.

NODE_ENV=production
HOST=127.0.0.1
PORT=4000

# Same-origin production builds can keep this as /api.
# If the frontend is served from a different origin, set the full API URL instead.
VITE_API_BASE_URL=/api

# Comma-separated browser origins allowed to call the API.
ALLOWED_ORIGINS=https://example.com,https://www.example.com

# Leave enabled when Nginx terminates HTTPS for the public domain.
ENABLE_HSTS=true

# PostgreSQL connection. Prefer DATABASE_URL, or use the PG* values below.
DATABASE_URL=postgresql://oilmart_user:change-me@127.0.0.1:5432/oilmartpro
PGSSLMODE=disable

# Alternative discrete PostgreSQL settings.
# PGHOST=127.0.0.1
# PGPORT=5432
# PGDATABASE=oilmartpro
# PGUSER=oilmart_user
# PGPASSWORD=change-me
# PGSSLMODE=require

# Database pool tuning.
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=10000

# First admin account created during database initialization.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-long-random-password
ADMIN_EMAIL=admin@example.com

# Runtime safety settings.
SESSION_TTL_MS=604800000
MAX_REQUEST_BODY_BYTES=1048576
HEALTH_INCLUDE_COUNTS=false
